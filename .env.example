# LangOps 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# ============ Langfuse ============
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=sk-lf-xxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxx

# ============ LLM Provider ============
# OpenAI（默认）
OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# 通义千问（Qwen）
# DASHSCOPE_API_KEY=sk-xxxxx

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxxxx

# ============ Prometheus ============
PROMETHEUS_URL=http://prometheus:9090
# Prometheus 认证（可选）
# PROMETHEUS_USER=admin
# PROMETHEUS_PASSWORD=xxxxx

# ============ 阿里云 ============
ALIYUN_ACCESS_KEY_ID=xxxxx
ALIYUN_ACCESS_KEY_SECRET=xxxxx
ALIYUN_REGION=cn-hangzhou
ALIYUN_CMS_ENDPOINT=metrics.aliyuncs.com

# ============ 通知渠道 ============
# 飞书 Webhook
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx

# 钉钉 Webhook
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxxxx

# Slack Webhook
# SLACK_WEBHOOK=https://hooks.slack.com/services/xxxxx

# ============ Redis（可选） ============
REDIS_URL=redis://localhost:6379

# ============ ChromaDB（可选） ============
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ============ JIRA 集成（可选） ============
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_USERNAME=your-email@example.com
# JIRA_API_TOKEN=xxxxx
# JIRA_PROJECT_KEY=ALERTS
# JIRA_ENABLED=false

# ============ Kubernetes ============
K8S_API_SERVER=https://127.0.0.1:6443
K8S_CA_CERT=/path/to/ca.crt
K8S_TOKEN=xxxxx
# K8s 认证方式（二选一：token 或 kubeconfig）
# KUBECONFIG=/path/to/.kube/config
