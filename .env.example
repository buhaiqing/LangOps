# LangOps 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# ============ Application ============
DEBUG=false
LOG_LEVEL=INFO

# ============ LLM ============
# 统一使用 LLM_API_KEY，支持 OpenAI / 通义千问 / DeepSeek 等兼容接口
LLM_API_KEY=sk-xxxxx
# LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.2

# ============ Langfuse ============
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-test-xxxxx
LANGFUSE_SECRET_KEY=sk-test-xxxxx

# ============ Prometheus ============
PROMETHEUS_URL=http://localhost:9090

# ============ Vector Store (ChromaDB) ============
VECTOR_HOST=localhost
VECTOR_PORT=8001

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ Storage (可选) ============
# 默认 SQLite，无需额外配置
# STORAGE_URL=sqlite:///.langops/data.db
# STORAGE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/langops

# ============ Aliyun CMS (可选) ============
# ALIYUN_ACCESS_KEY_ID=your-access-key
# ALIYUN_ACCESS_KEY_SECRET=your-secret-key
# ALIYUN_REGION=cn-hangzhou
# ALIYUN_CMS_ENDPOINT=metrics.aliyuncs.com

# ============ 通知渠道 (可选) ============
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxxxx
# WECHAT_WORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxx

# ============ 告警降噪 ============
# ALERT_DEDUP_ENABLED=true
# ALERT_DEDUP_WINDOW_SECONDS=900

# ============ 自动修复 ============
# REMEDIATION_ENABLED=true
# REMEDIATION_EXECUTION_ENABLED=false

# ============ JIRA 集成 (可选) ============
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_USERNAME=your-email@example.com
# JIRA_API_TOKEN=your-api-token
# JIRA_PROJECT_KEY=ALERTS
# JIRA_ENABLED=false
